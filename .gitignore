# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── Build / packaging ─────────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ── uv ────────────────────────────────────────────────────────────────────────
# Lock file is intentionally tracked; exclude only runtime artifacts
.uv/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# ── IDEs / editors ────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Data files (large, not part of the source) ────────────────────────────────
*.parquet
*.csv

# ── Docker runtime output ─────────────────────────────────────────────────────
# Files produced by `docker run` land as root-owned in the project dir
output.*
